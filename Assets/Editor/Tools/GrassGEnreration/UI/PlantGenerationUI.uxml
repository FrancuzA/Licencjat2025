<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement style="flex-grow: 1;">
        <ui:Label text="Plant Generator" name="Name" style="-unity-text-align: upper-center; -unity-font-style: italic; font-size: 18px;"/>
        <ui:Button text="Create new region" name="CreateRegion" style="background-image: url(&quot;project://database/Assets/Materials/UI/PopUpTextHighlight.png?fileID=2800000&amp;guid=f0668012e2363ba43a5f966001fdd259&amp;type=3#PopUpTextHighlight&quot;); background-color: rgba(128, 128, 128, 0); -unity-background-image-tint-color: rgb(203, 0, 255); background-size: 125% 164%; color: rgb(255, 255, 255);"/>
        <ui:VisualElement name="Separator" style="flex-grow: 0; height: 15px; align-self: center; align-content: flex-start; width: 345px;"/>
        <ui:Label text="Regions" name="RegionLabel" style="-unity-text-align: upper-center;"/>
        <ui:ListView name="RegionList" fixed-item-height="50" virtualization-method="DynamicHeight" show-border="true" show-foldout-header="false" style="flex-grow: 0;"/>
    </ui:VisualElement>
</ui:UXML>
